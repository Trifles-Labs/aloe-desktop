{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main window, including the custom title bar's drag region and window controls.",
  "windows": ["main"],
  "permissions": [
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:event:default",
    "updater:default",
    "process:allow-restart"
  ]
}
