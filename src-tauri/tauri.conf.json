{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Aloe Desktop",
    "version": "0.3.0",
    "identifier": "com.aloe.desktop",
    "build": {
        "beforeDevCommand": "bun run dev",
        "beforeBuildCommand": "bun run build",
        "devUrl": "http://127.0.0.1:1420",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Aloe Desktop",
                "width": 980,
                "height": 700,
                "minWidth": 780,
                "minHeight": 560,
                "decorations": false,
                "visible": false
            },
            {
                "label": "orb",
                "url": "orb.html",
                "title": "Aloe",
                "width": 600,
                "height": 600,
                "decorations": false,
                "transparent": true,
                "alwaysOnTop": true,
                "skipTaskbar": true,
                "resizable": false,
                "shadow": false,
                "center": true,
                "visible": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "createUpdaterArtifacts": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": {
            "resources/vosk-model-small-en-us-0.15": "resources/vosk-model-small-en-us-0.15"
        }
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMwNUZBNjRCNDdFNEQ4ODcKUldTSDJPUkhTNlpmTU1tRHhFQWZZTWJHUW1wbFpSWWxHaTFUeS9QVktyZzRKNjR2VWx4aTlGYlAK",
            "endpoints": [
                "https://api.247autoarmy.in/api/updates/{{target}}/{{arch}}/{{current_version}}"
            ]
        }
    }
}
