{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aloe Desktop",
  "version": "0.1.0",
  "identifier": "com.aloe.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aloe Desktop",
        "width": 980,
        "height": 700,
        "minWidth": 780,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
